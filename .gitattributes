# Enforce LF line endings for all text files across all OSes
* text=auto eol=lf

# Explicitly mark these as text files
*.js text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.html text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
